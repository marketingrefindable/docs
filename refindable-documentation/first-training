<div class="qq" id="q6"><div class="qq-n">Pregunta 2</div><p>¿Cuál es la diferencia entre Lifecycle Stage y Pipeline?</p><div class="qo"><div class="qopt" onclick="ans(this,'q6',1)"><div class="mk">A</div>Lifecycle = etapa del contacto. Pipeline = etapa del deal.</div><div class="qopt" onclick="ans(this,'q6',0)"><div class="mk">B</div>Son lo mismo con nombres diferentes</div><div class="qopt" onclick="ans(this,'q6',0)"><div class="mk">C</div>Lifecycle es para marketing, Pipeline para service</div></div><div class="qfb" id="q6-fb"></div></div>
<div class="qq" id="q7"><div class="qq-n">Pregunta 3</div><p>¿Dónde encontrás Workflows en HubSpot?</p><div class="qo"><div class="qopt" onclick="ans(this,'q7',0)"><div class="mk">A</div>En CRM</div><div class="qopt" onclick="ans(this,'q7',0)"><div class="mk">B</div>En Reporting</div><div class="qopt" onclick="ans(this,'q7',1)"><div class="mk">C</div>En Automations</div></div><div class="qfb" id="q7-fb"></div></div>
</div>

<!-- S21: Glosario -->
<div class="sl" data-s="21">
<div class="badge">📖 Referencia</div>
<h2>Glosario rápido</h2>
<p>Para tener a mano. No hace falta memorizar todo, pero saber dónde buscar.</p>
<div class="gl">
<div class="gl-i"><div class="gl-t">Object</div><div class="gl-d">Tipo de registro: Contact, Company, Deal, Ticket</div></div>
<div class="gl-i"><div class="gl-t">Record</div><div class="gl-d">Una entrada individual ("Juan" = un record)</div></div>
<div class="gl-i"><div class="gl-t">Property</div><div class="gl-d">Campo de datos (nombre, email, monto...)</div></div>
<div class="gl-i"><div class="gl-t">Association</div><div class="gl-d">Relación entre objetos (Contact ↔ Company)</div></div>
<div class="gl-i"><div class="gl-t">Pipeline</div><div class="gl-d">Proceso por etapas de un Deal o Ticket</div></div>
<div class="gl-i"><div class="gl-t">Lifecycle Stage</div><div class="gl-d">Etapa del journey del contacto</div></div>
<div class="gl-i"><div class="gl-t">Workflow</div><div class="gl-d">Automatización que se dispara por condición</div></div>
<div class="gl-i"><div class="gl-t">Owner</div><div class="gl-d">Persona responsable de un registro</div></div>
<div class="gl-i"><div class="gl-t">View</div><div class="gl-d">Filtro guardado para ver ciertos registros</div></div>
<div class="gl-i"><div class="gl-t">Dashboard</div><div class="gl-d">Página con múltiples reportes visuales</div></div>
</div>
</div>

<!-- S22: Resultado -->
<div class="sl" data-s="22">
<div class="badge">🎉 Fin de la sesión</div>
<h2>Tu resultado</h2>
<div class="final-s" id="finalS">—</div>
<p style="text-align:center;font-size:16px" id="finalM">Completá los quizzes y ejercicios para ver tu score.</p>
<div style="background:var(--s1);border:1px solid var(--bd);border-radius:var(--rad);padding:20px;margin:24px 0">
<h3 style="font-family:'Space Grotesk',sans-serif;font-size:16px;margin:0 0 12px">📌 Para la próxima sesión</h3>
<p style="font-size:14px">La <strong>Sesión 2</strong> es sobre <strong>Contactos, Companies y Deals</strong> en profundidad. Vamos a crear registros, asociarlos, y trabajar con datos reales.</p>
<p style="font-size:14px"><strong>Tarea opcional:</strong> Entrá a un portal de HubSpot y explorá un poco. Buscá un contacto, mirá su timeline, y navegá los menús.</p>
</div>
<p style="text-align:center;color:var(--td);font-size:13px;margin-top:20px">Refindable Academy 2026 · Track Trainees · Sesión 1 de 12</p>
</div>

</div>
<div class="bot"><button class="btn bp" id="bP" onclick="prev()" disabled>← Anterior</button><div class="sc" id="sCt">1 / 22</div><button class="btn bn" id="bN" onclick="next()">Siguiente →</button></div>
</div>

<script>
const T=23;let cur=0,pts=0,ad={},mSel={l:null,r:null},mDone=0,mTotal=5;
const qSlides={5:['q1','q2'],10:['q3','q4'],20:['q5','q6','q7']};
const scSlides={15:'sc1',16:'sc2',19:'sc3'};

function upd(){
document.querySelectorAll('.sl').forEach(s=>s.classList.remove('active'));
document.querySelector(`[data-s="${cur}"]`).classList.add('active');
document.getElementById('pgFill').style.width=((cur/(T-1))*100)+'%';
document.getElementById('pgText').textContent=`${cur+1} / ${T}`;
document.getElementById('sCt').textContent=`${cur+1} / ${T}`;
document.getElementById('scoreBadge').textContent=`✨ ${pts} pts`;
document.getElementById('bP').disabled=cur===0;
const b=document.getElementById('bN');
if(cur===T-1){b.style.display='none';updFinal();return}
b.style.display='flex';
const sl=document.querySelector(`[data-s="${cur}"]`);
const qz=sl.dataset.quiz;
if(qz){
  let locked=false;
  if(qSlides[cur]){locked=!qSlides[cur].every(q=>ad[q]!==undefined)}
  if(scSlides[cur]){locked=ad[scSlides[cur]]===undefined}
  if(cur===9){locked=mDone<mTotal}// matching
  if(locked){b.classList.add('locked');b.textContent='🔒 Completá para avanzar'}
  else{b.classList.remove('locked');b.textContent='Siguiente →'}
}else{b.classList.remove('locked');b.textContent=cur===T-2?'Ver resultado →':'Siguiente →'}
document.querySelector('.sa').scrollTop=0;
}

function next(){const b=document.getElementById('bN');if(b.classList.contains('locked'))return;if(cur<T-1){cur++;upd()}}
function prev(){if(cur>0){cur--;upd()}}

function ans(el,qId,c){
if(ad[qId]!==undefined)return;
ad[qId]=c;if(c)pts+=10;
const q=document.getElementById(qId),opts=q.querySelectorAll('.qopt'),fb=document.getElementById(qId+'-fb');
opts.forEach(o=>o.classList.add('dis'));
if(c){el.classList.add('correct');fb.textContent='✅ ¡Correcto! +10 pts';fb.className='qfb show fbok';q.classList.add('ok')}
else{el.classList.add('wrong');opts.forEach(o=>{if(o.getAttribute('onclick')?.includes(',1)')){o.classList.remove('dis');o.classList.add('correct')}});fb.textContent='❌ Incorrecta.';fb.className='qfb show fbbad';q.classList.add('bad')}
upd();
}

function scAns(el,scId,c){
if(ad[scId]!==undefined)return;
ad[scId]=c;if(c)pts+=15;
const sc=document.getElementById(scId),opts=sc.querySelectorAll('.scenario-opt'),fb=document.getElementById(scId+'-fb');
opts.forEach(o=>o.classList.add('dis'));
if(c){el.classList.add('correct');fb.textContent='✅ ¡Correcto! +15 pts. Siempre registrá todo en el CRM.';fb.className='scenario-fb show sfbok'}
else{el.classList.add('wrong');opts.forEach(o=>{if(o.getAttribute('onclick')?.includes(',1)')){o.classList.remove('dis');o.classList.add('correct')}});
  if(scId==='sc1')fb.textContent='❌ Hay que registrar TODO: contacto, empresa, deal, actividad y tarea de follow-up.';
  else if(scId==='sc2')fb.textContent='❌ El timeline del contacto tiene todo el historial. Ahí ves qué habló Sol.';
  else fb.textContent='❌ CRM → Deals, con filtros. Es la forma más directa.';
  fb.className='scenario-fb show sfbbad'}
upd();
}

// Matching
function matchClick(el,side){
  if(el.classList.contains('matched'))return;
  if(side==='l'){
    document.querySelectorAll('#ml .match-item').forEach(i=>i.classList.remove('selected'));
    el.classList.add('selected');mSel.l=el;
  }else{
    document.querySelectorAll('#mr .match-item').forEach(i=>i.classList.remove('selected'));
    el.classList.add('selected');mSel.r=el;
  }
  if(mSel.l&&mSel.r){
    if(mSel.l.dataset.m===mSel.r.dataset.m){
      mSel.l.classList.remove('selected');mSel.r.classList.remove('selected');
      mSel.l.classList.add('matched');mSel.r.classList.add('matched');
      mDone++;pts+=5;
      if(mDone===mTotal){document.getElementById('matchScore').style.display='block';document.getElementById('matchScore').textContent=`✅ ¡Todo correcto! +${mTotal*5} pts`}
    }else{
      mSel.l.classList.add('wrong-flash');mSel.r.classList.add('wrong-flash');
      const a=mSel.l,b2=mSel.r;
      setTimeout(()=>{a.classList.remove('selected','wrong-flash');b2.classList.remove('selected','wrong-flash')},600);
    }
    mSel={l:null,r:null};
    upd();
  }
}

function st(el,i){
  el.parentElement.querySelectorAll('.sn-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  const p=el.closest('.sn').querySelectorAll('.sn-p');
  p.forEach(x=>x.classList.remove('active'));p[i].classList.add('active');
}

function updFinal(){
  const el=document.getElementById('finalS'),msg=document.getElementById('finalM');
  const maxPts=70+25+45;// 7 quiz*10 + 5 match*5 + 3 scenarios*15
  const pct=Math.round((pts/maxPts)*100);
  el.textContent=pts+' pts ('+pct+'%)';
  if(pct>=80){el.className='final-s great';msg.textContent='🔥 Excelente. Dominás los fundamentos. Nos vemos en la Sesión 2.'}
  else if(pct>=50){el.className='final-s ok';msg.textContent='👍 Bien, pero repasá donde fallaste antes de la próxima sesión.'}
  else{el.className='final-s low';msg.textContent='📖 Necesitás repasar. Volvé a las slides y revisá los conceptos.'}
}

document.addEventListener('keydown',e=>{if(e.key==='ArrowRight'||e.key===' '){e.preventDefault();next()}if(e.key==='ArrowLeft'){e.preventDefault();prev()}});
upd();
</script>
</body>
</html>
