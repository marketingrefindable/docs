.scenario-opt.dis{pointer-events:none;opacity:.35}.scenario-opt.dis.correct{opacity:1}
.scenario-fb{margin-top:10px;font-size:12px;padding:8px 12px;border-radius:var(--rads);display:none;line-height:1.5}
.scenario-fb.show{display:block}.scenario-fb.sfbok{background:var(--gs);color:var(--g)}.scenario-fb.sfbbad{background:var(--rs);color:var(--r)}
/* Discussion */
.disc{background:rgba(168,85,247,.08);border:1px solid rgba(168,85,247,.2);border-radius:var(--rad);padding:24px;margin:16px 0}
.disc h3{font-family:'Space Grotesk',sans-serif;font-size:16px;font-weight:600;color:#a855f7;margin:0 0 10px;display:flex;align-items:center;gap:8px}
.disc p{font-size:14px;color:var(--tm);margin-bottom:8px}
