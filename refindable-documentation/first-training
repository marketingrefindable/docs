.qfb.show{display:block}.qfb.fbok{background:var(--gs);color:var(--g)}.qfb.fbbad{background:var(--rs);color:var(--r)}
/* Match exercise */
.match-area{margin:16px 0}
.match-cols{display:grid;grid-template-columns:1fr 40px 1fr;gap:8px;align-items:start}
.match-left,.match-right{display:flex;flex-direction:column;gap:8px}
