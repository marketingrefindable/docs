.tt td{padding:10px 14px;border-bottom:1px solid var(--bd);color:var(--tm)}
.tt tr:last-child td{border-bottom:none}.tt tr:hover td{background:var(--s1)}
.tag{display:inline-block;padding:2px 8px;border-radius:100px;font-size:10px;font-weight:600}
.tag.f{background:var(--acs);color:var(--ac)}.tag.st{background:var(--gs);color:var(--g)}.tag.pr{background:var(--os);color:var(--o)}.tag.en{background:var(--hss);color:var(--hs)}
/* Hub grid */
.hg{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:10px;margin:16px 0}
.hc{background:var(--s1);border:1px solid var(--bd);border-radius:var(--rads);padding:16px;transition:all .3s}
